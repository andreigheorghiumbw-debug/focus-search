{
  "manifest_version": 3,
  "name": "FocusSearch: Human-Only Filter",
  "version": "2.6.0",
  "description": "Purge AI-slop and filter Google results for human-generated content.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FocusSearch",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "host_permissions": [
    "*://*.google.com/search*",
    "*://*.google.ro/search*"
  ]
}